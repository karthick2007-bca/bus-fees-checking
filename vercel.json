{
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "dec_02/**",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dec_02/build/web"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/dec_02/build/web/$1"
    }
  ]
}